generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  PROFESSOR
  TEAM_LEADER
}

enum Plan {
  FREE
  PRO
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  role           Role     @default(STUDENT)
  avatarUrl      String?
  preferredName  String?
  bio            String?
  school         String?
  major          String?
  githubUrl        String?
  linkedinUrl      String?
  personalLinks    Json?
  status           String?
  statusExpiresAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  ownedCourses     Course[]        @relation("CourseOwner")
  ownedProjects    Project[]       @relation("ProjectOwner")
  projectMembers   ProjectMember[]
  assignedTasks    Task[]          @relation("TaskAssignee")
  createdTasks     Task[]          @relation("TaskCreator")
  activityLogs     ActivityLog[]
  peerReviewsGiven PeerReview[]    @relation("ReviewGiver")
  peerReviewsGot   PeerReview[]    @relation("ReviewReceiver")
  uploadedFiles    ProjectFile[]
  sentInvites      ProjectInvite[]  @relation("InviteSender")
  feedbacks        Feedback[]
  bugReports       BugReport[]
  chatMessages     ChatMessage[]
  chatReactions    ChatReaction[]
  chatReactionPref ChatReactionPreference[]
  subscription     Subscription?
}

model Course {
  id          String   @id @default(uuid())
  name        String
  code        String
  description String?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User      @relation("CourseOwner", fields: [ownerId], references: [id])
  projects Project[] @relation("CourseProjects")

  @@unique([code, ownerId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  courseCode  String?
  courseId       String?
  ownerId        String
  deadline       DateTime?
  status         ProjectStatus @default(ACTIVE)
  archivedAt     DateTime?
  archivedReason String?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  owner    User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  course   Course?         @relation("CourseProjects", fields: [courseId], references: [id], onDelete: SetNull)
  members  ProjectMember[]
  tasks    Task[]
  reviews  PeerReview[]
  logs     ActivityLog[]
  files    ProjectFile[]
  invites  ProjectInvite[]
  chatMessages     ChatMessage[]
  chatReactionPref ChatReactionPreference[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      Role     @default(STUDENT)
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  projectId   String
  creatorId   String
  assigneeId  String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator  User          @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  logs     ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  taskId    String?
  action    String   // e.g. "TASK_CREATED", "TASK_COMPLETED", "FILE_UPLOADED"
  metadata  Json?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id])
}

model ProjectFile {
  id           String   @id @default(uuid())
  projectId    String
  uploadedById String
  name         String
  url          String
  size         Int?
  mimeType     String?
  createdAt    DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])
}

model ProjectInvite {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  projectId   String
  email       String
  role        Role      @default(STUDENT)
  invitedById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InviteSender", fields: [invitedById], references: [id])
}

model PeerReview {
  id         String   @id @default(uuid())
  projectId  String
  giverId    String
  receiverId String
  quality    Int      // 1-5
  communication Int   // 1-5
  timeliness Int      // 1-5
  initiative Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  giver    User    @relation("ReviewGiver", fields: [giverId], references: [id])
  receiver User    @relation("ReviewReceiver", fields: [receiverId], references: [id])

  @@unique([projectId, giverId, receiverId])
}

// ── Public feedback shown on landing page ────────────────────────────────────
model Feedback {
  id        String   @id @default(uuid())
  name      String   // display name (can be a first name or alias)
  role      String?  // e.g. "Student at UCLA", "Professor"
  message   String
  rating    Int      @default(5) // 1-5 stars
  approved  Boolean  @default(false) // admin toggles to show publicly
  userId    String?  // null if submitted anonymously / before login
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ── Project Chat ──────────────────────────────────────────────────────────────
model ChatMessage {
  id        String   @id @default(uuid())
  projectId String
  senderId  String
  text      String?
  imageUrl  String?
  createdAt DateTime @default(now())

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender    User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions ChatReaction[]
}

model ChatReaction {
  id        String @id @default(uuid())
  messageId String
  userId    String
  emoji     String @default("👍")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model ChatReactionPreference {
  id        String @id @default(uuid())
  userId    String
  projectId String
  emoji     String @default("👍")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// ── Subscription / billing ────────────────────────────────────────────────────
model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 Plan      @default(FREE)
  status               String    @default("active") // active | trialing | past_due | canceled | incomplete
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Bug reports submitted by users ───────────────────────────────────────────
enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  WONT_FIX
}

model BugReport {
  id          String    @id @default(uuid())
  title       String
  description String
  steps       String?   // steps to reproduce
  email       String?   // contact email for follow-up
  status      BugStatus @default(OPEN)
  userId      String?   // null if not logged in
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}